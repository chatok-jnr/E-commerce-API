generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User{
  id String @id @default(uuid())

  name String
  email String @unique
  password String

  profileImage String?
  bio String?
  dob DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles UserRole[]

  @@index([email], name: "email_index")
  @@map("users")
}

enum Role {
  ADMIN
  CUSTOMER
}

model UserRole{
  id String @id @default(uuid())
  userId String
  role Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role], name: "user_role_unique")
}